@using System.Text.Json
@inject IClipboardService Clipboard

@if (Open)
{
    <section class="json-drawer" aria-label="@Text["Json.PayloadLabel"]">
        <header class="json-head">
            <span class="mono json-braces">{ }</span>
            <div class="json-head-text">
                <strong>@Text["Json.PayloadLabel"]</strong>
                <span>@Text["Workspace.JsonHint"]</span>
            </div>
            <div class="panel-head-spacer"></div>
            @if (!string.IsNullOrWhiteSpace(copyFeedback))
            {
                <span class="tl-empty-sub" aria-live="polite">@copyFeedback</span>
            }
                <button class="ghost-btn"
                        type="button"
                        disabled="@isCopying"
                        @onclick="CopyAsync"
                        aria-label="@Text["Json.CopyLabel"]">
                    @(isCopying ? "..." : Text["Json.Copy"])
                </button>
                <button class="icon-btn"
                        type="button"
                        @onclick="() => CloseRequested.InvokeAsync()"
                        aria-label="@Text["Json.CloseLabel"]">
                    x
                </button>
        </header>
        <div class="json-scroll">
            <pre class="json-block">@FormattedPayload</pre>
        </div>
    </section>
}

@code {
    [Parameter, EditorRequired] public UiText Text { get; set; } = default!;
    [Parameter] public string Payload { get; set; } = string.Empty;
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback CloseRequested { get; set; }

    private bool isCopying;
    private string? copyFeedback;
    private string? previousPayload;

    private string FormattedPayload => FormatJson(Payload);

    protected override void OnParametersSet()
    {
        if (!string.Equals(previousPayload, Payload, StringComparison.Ordinal))
        {
            previousPayload = Payload;
            copyFeedback = null;
        }
    }

    private async Task CopyAsync()
    {
        if (isCopying)
            return;

        isCopying = true;
        copyFeedback = null;

        var copied = await Clipboard.CopyTextAsync(FormattedPayload);
        copyFeedback = copied ? Text["Json.Copied"] : Text["Json.CopyFailed"];
        isCopying = false;
    }

    private static string FormatJson(string payload)
    {
        if (string.IsNullOrWhiteSpace(payload))
            return string.Empty;

        try
        {
            using var document = JsonDocument.Parse(payload);
            return JsonSerializer.Serialize(document.RootElement, JsonOptions);
        }
        catch (JsonException)
        {
            return payload;
        }
    }

    private static readonly JsonSerializerOptions JsonOptions = new()
    {
        WriteIndented = true
    };
}
