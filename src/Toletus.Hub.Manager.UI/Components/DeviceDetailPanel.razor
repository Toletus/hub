<aside class="thm-detail device-detail-panel">
    @if (ShouldRenderChildContentFallback)
    {
        @ChildContent
    }
    else if (SelectedDevice is null)
    {
        <section class="thm-empty-state">
            <h2>@T("Workspace.EmptyTitle")</h2>
            <p>@T("Workspace.EmptyText")</p>
        </section>
    }
    else
    {
        <section class="thm-essentials">
            <div class="thm-row">
                <div>
                    <h2>@SelectedDevice.Name</h2>
                    <div class="thm-meta">
                        @SelectedDevice.TypeLabel &middot; @(SelectedDevice.Connected ? T("Workspace.Connected") : T("Workspace.Disconnected")) &middot; firmware @GetConfigurationValue("firmware_version", "-")
                    </div>
                </div>
                <span class="thm-pill @ResolvedDeviceStatusClass">
                    @(SelectedDevice.Connected ? "Online" : T("Workspace.Disconnected"))
                </span>
            </div>

            <div class="thm-kv">
                <div><span>ID</span><strong>@SelectedDevice.Id</strong></div>
                <div><span>@T("Workspace.Serial")</span><strong>@(SelectedDevice.SerialNumber ?? "-")</strong></div>
                <div><span>IP</span><strong>@SelectedDevice.IpAddress</strong></div>
                <div><span>MAC</span><strong>@GetConfigurationValue("mac", "-")</strong></div>
            </div>
        </section>

        <div class="thm-tabs">
            <button class="thm-tab @(ActiveDetailTab == "config" ? "active" : null)" type="button" @onclick='() => ActiveDetailTab = "config"'>
                @T("Group.Settings")
            </button>
            <button class="thm-tab @(ActiveDetailTab == "sm25" ? "active" : null)" type="button" @onclick='() => ActiveDetailTab = "sm25"'>
                SM25
            </button>
        </div>

        @if (ActiveDetailTab == "config")
        {
            <section class="thm-card">
                <header class="thm-card-head">
                    <h3>@T("Config.Edit")</h3>
                    <button class="thm-secondary" @onclick="RefreshConfigurationAsync" disabled="@IsConfigurationActionDisabled">
                        @T("Command.GetProperties")
                    </button>
                </header>

                @if (IsConfigurationLoading)
                {
                    <div class="thm-empty">@T("Message.CommandPending")</div>
                }

                @foreach (var group in GetConfigurationGroups())
                {
                    <section class="thm-config-group">
                        <div class="thm-group-title">
                            <strong>@T(group.Key)</strong>
                            <span>@GetConfigurationGroupHint(group.Key)</span>
                        </div>

                        <div class="thm-form" aria-busy="@IsConfigurationLoading">
                            @foreach (var field in group)
                            {
                                <ConfigurationField Field="field"
                                                    Value="@GetConfigurationValue(field.Id)"
                                                    Disabled="@IsFieldDisabled(field)"
                                                    Text="Text"
                                                    ValueChanged="OnConfigurationValueChanged" />
                            }
                        </div>
                    </section>
                }

                <div class="thm-config-actions">
                    <button class="thm-cmd brand" @onclick="SendVisibleConfigurationAsync" disabled="@IsConfigurationActionDisabled">
                        @T("Command.SendConfiguration")
                    </button>
                    <button class="thm-cmd" @onclick="RefreshConfigurationAsync" disabled="@IsConfigurationActionDisabled">
                        @T("Command.GetProperties")
                    </button>
                </div>
            </section>
        }
        else
        {
            <section class="thm-card">
                <h3>@T("Group.Biometrics")</h3>
                <Sm25Section Modules="SelectedModules"
                             Catalog="Catalog"
                             Text="Text"
                             CurrentCommandId="CurrentCommandId"
                             IsBusy="IsBusy"
                             IsConnected="SelectedDevice.Connected"
                             CommandRequested="ExecuteModuleCommandAsync" />
            </section>
        }
    }
</aside>

@code {
    private string ActiveDetailTab { get; set; } = "config";

    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public DeviceRefViewModel? Device { get; set; }
    [Parameter] public ManagerUiState? State { get; set; }
    [Parameter] public DeviceCapabilityCatalog? Catalog { get; set; }
    [Parameter] public UiText? Text { get; set; }
    [Parameter] public IReadOnlyList<ConfigurationFieldCapability>? ConfigurationFields { get; set; }
    [Parameter] public IDictionary<string, string>? ConfigurationValues { get; set; }
    [Parameter] public EventCallback RefreshConfigurationRequested { get; set; }
    [Parameter] public EventCallback<string> SendConfigurationRequested { get; set; }
    [Parameter] public EventCallback<string> CommandRequested { get; set; }
    [Parameter] public EventCallback<string> ModuleCommandRequested { get; set; }
    [Parameter] public EventCallback<(string FieldId, string Value)> ConfigurationValueChanged { get; set; }
    [Parameter] public string? DeviceStatusClass { get; set; }
    [Parameter] public bool? IsBusyOverride { get; set; }
    [Parameter] public bool? IsConfigurationLoadingOverride { get; set; }
    [Parameter] public string? CurrentCommandIdOverride { get; set; }

    private DeviceRefViewModel? SelectedDevice => Device ?? State?.SelectedDevice;

    private IDictionary<string, string> Values =>
        ConfigurationValues ?? State?.ConfigurationValues ?? LocalConfigurationValues;

    private Dictionary<string, string> LocalConfigurationValues { get; } = new(StringComparer.OrdinalIgnoreCase);

    private bool IsBusy => IsBusyOverride ?? State?.IsBusy ?? false;

    private bool IsConfigurationLoading => IsConfigurationLoadingOverride ?? State?.IsConfigurationLoading ?? false;

    private string? CurrentCommandId => CurrentCommandIdOverride ?? State?.CurrentCommandId;

    private bool IsConfigurationActionDisabled =>
        IsBusy || IsConfigurationLoading || SelectedDevice?.Connected != true;

    private string ResolvedDeviceStatusClass =>
        DeviceStatusClass ?? (SelectedDevice?.Connected == true ? "ok" : "off");

    private bool ShouldRenderChildContentFallback =>
        ChildContent is not null &&
        Device is null &&
        State is null &&
        Catalog is null &&
        Text is null &&
        ConfigurationFields is null &&
        ConfigurationValues is null;

    private IReadOnlyList<DeviceModuleKind> SelectedModules =>
        SelectedDevice?.Modules ?? Array.Empty<DeviceModuleKind>();

    private string T(string key) => Text?[key] ?? key;

    private IReadOnlyList<IGrouping<string, ConfigurationFieldCapability>> GetConfigurationGroups()
    {
        if (SelectedDevice is null)
            return Array.Empty<IGrouping<string, ConfigurationFieldCapability>>();

        var fields = ConfigurationFields ?? Catalog?.GetConfigurationFields(SelectedDevice.Type) ?? Array.Empty<ConfigurationFieldCapability>();
        return fields.GroupBy(field => field.GroupKey).ToList();
    }

    private string GetConfigurationValue(string fieldId, string fallback = "") =>
        Values.TryGetValue(fieldId, out var value) ? value : fallback;

    private async Task OnConfigurationValueChanged((string FieldId, string Value) change)
    {
        Values[change.FieldId] = change.Value;

        if (ConfigurationValueChanged.HasDelegate)
            await ConfigurationValueChanged.InvokeAsync(change);
    }

    private bool IsFieldDisabled(ConfigurationFieldCapability field) =>
        IsConfigurationLoading || (field.RequiresConnection && SelectedDevice?.Connected != true);

    private string GetConfigurationGroupHint(string groupKey) =>
        groupKey switch
        {
            "Config.LiteNet3" => "LiteNet3",
            "Config.Biometrics" => "SM25",
            "Config.Notification" => "LiteNet2",
            "Config.Operation" => "comum",
            _ => "device"
        };

    private async Task RefreshConfigurationAsync()
    {
        if (RefreshConfigurationRequested.HasDelegate)
            await RefreshConfigurationRequested.InvokeAsync();
        else if (State is not null)
            await State.RefreshConfigurationAsync();
    }

    private async Task SendVisibleConfigurationAsync()
    {
        foreach (var groupKey in GetConfigurationGroups().Select(group => group.Key))
            await SendConfigurationAsync(groupKey);
    }

    private async Task SendConfigurationAsync(string moduleKey)
    {
        if (SendConfigurationRequested.HasDelegate)
            await SendConfigurationRequested.InvokeAsync(moduleKey);
        else if (State is not null)
            await State.SendConfigurationAsync(moduleKey);
    }

    private async Task ExecuteModuleCommandAsync(string commandId)
    {
        if (ModuleCommandRequested.HasDelegate)
            await ModuleCommandRequested.InvokeAsync(commandId);
        else if (CommandRequested.HasDelegate)
            await CommandRequested.InvokeAsync(commandId);
        else if (State is not null)
            await State.ExecuteAsync(commandId);
    }
}
