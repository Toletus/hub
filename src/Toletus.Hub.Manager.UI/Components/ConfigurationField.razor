@if (Field.ControlKind == "color")
{
    var color = NormalizeHex(string.IsNullOrWhiteSpace(Value) ? "#0000FF" : Value);
    <label class="field">
        <span class="field-label">@T(Field.LabelKey)</span>
        <span class="color-wrap">
            <input type="color" class="color-swatch" value="@color" @onchange="args => SetValueAsync(NormalizeHex(args.Value?.ToString()))" disabled="@Disabled" />
            <input class="input mono" value="@color" @onchange="args => SetValueAsync(NormalizeHex(args.Value?.ToString()))" disabled="@Disabled" />
        </span>
    </label>
}
else
{
    <label class="field">
        <span class="field-label">@T(Field.LabelKey)</span>

        @switch (Field.ControlKind)
        {
            case "read":
                <input class="input @(Field.Id is "firmware_version" or "mac" ? "mono" : null)" value="@DisplayValue" readonly />
                break;
            case "toggle":
                <input type="checkbox" checked="@IsTrue(Value)" @onchange="SetToggleValueAsync" disabled="@Disabled" />
                break;
            case "select":
            case "boolean_select":
                <span class="select-wrap">
                <select class="input" value="@Value" @onchange="args => SetValueAsync(args.Value?.ToString() ?? string.Empty)" disabled="@Disabled">
                    @foreach (var option in GetFieldOptions(Field.Id, Field.ControlKind))
                    {
                        <option value="@option.Value">@T(option.LabelKey)</option>
                    }
                </select>
                </span>
                break;
            default:
                <input class="input @(Field.ControlKind == "number" ? "mono" : null)"
                       type="@InputType"
                       value="@Value"
                       @onchange="args => SetValueAsync(args.Value?.ToString() ?? string.Empty)"
                       placeholder="@(Field.PlaceholderKey is null ? string.Empty : T(Field.PlaceholderKey))"
                       disabled="@Disabled" />
                break;
        }
    </label>
}

@code {
    [Parameter, EditorRequired] public ConfigurationFieldCapability Field { get; set; } = default!;
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public UiText? Text { get; set; }
    [Parameter] public EventCallback<(string FieldId, string Value)> ValueChanged { get; set; }

    private string DisplayValue => string.IsNullOrWhiteSpace(Value) && Field.Id == "firmware_version" ? "-" : Value;

    private string InputType =>
        Field.ControlKind == "password" ? "password" :
        Field.ControlKind == "number" ? "number" :
        "text";

    private string T(string key) => Text?[key] ?? key;

    private Task SetValueAsync(string value) =>
        ValueChanged.InvokeAsync((Field.Id, value));

    private Task SetToggleValueAsync(ChangeEventArgs args) =>
        SetValueAsync(args.Value?.ToString() == "true" ? "true" : "false");

    private static bool IsTrue(string? value) =>
        value is "true" or "True" or "Sim" or "1";

    private static IReadOnlyList<(string Value, string LabelKey)> GetFieldOptions(string fieldId, string controlKind)
    {
        if (controlKind == "boolean_select")
        {
            return
            [
                ("false", "Option.No"),
                ("true", "Option.Yes")
            ];
        }

        return fieldId switch
        {
            "ip_mode" =>
            [
                ("DHCP", "Option.IpMode.Dhcp"),
                ("Static", "Option.IpMode.Static")
            ],
            "flow_mode" =>
            [
                ("None", "Option.Flow.None"),
                ("Entry", "Option.Flow.Entry"),
                ("Exit", "Option.Flow.Exit"),
                ("Both", "Option.Flow.Both")
            ],
            "l3_flow_in" or "l3_flow_out" =>
            [
                ("controls", "Option.FlowPermission.Controls"),
                ("free", "Option.FlowPermission.Free"),
                ("blocks", "Option.FlowPermission.Blocks")
            ],
            "l3_flow_picto_wait_in" or "l3_flow_picto_wait_out" =>
            [
                ("0", "Option.Picto.Off"),
                ("1", "Option.Picto.Arrow"),
                ("2", "Option.Picto.Blocked"),
                ("3", "Option.Picto.ArrowAndBlocked")
            ],
            "display_mode" =>
            [
                ("message", "Option.Display.Message"),
                ("counters", "Option.Display.Counters")
            ],
            "fingerprint_identification_mode" =>
            [
                ("CardOrFingerprint", "Option.Fingerprint.CardOrFingerprint"),
                ("Fingerprint", "Option.Fingerprint.Fingerprint"),
                ("Card", "Option.Fingerprint.Card")
            ],
            "notify_tone" =>
            [
                ("0", "Option.NotifyTone.Success"),
                ("1", "Option.NotifyTone.Alert"),
                ("2", "Option.NotifyTone.Silent")
            ],
            _ =>
            [
                ("", "Field.SelectOption")
            ]
        };
    }

    private static string NormalizeHex(string? value)
    {
        var cleaned = (value ?? string.Empty).Trim().TrimStart('#').ToUpperInvariant();
        return cleaned.Length == 6 && cleaned.All(Uri.IsHexDigit)
            ? $"#{cleaned}"
            : "#0000FF";
    }
}
