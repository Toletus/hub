<section class="device-strip" aria-label="@Text["Devices.Filters"]" role="listbox">
    @if (VisibleDevices.Count == 0)
    {
        <span class="thm-empty">@Text["Devices.Empty"]</span>
    }
    else
    {
        @foreach (var device in VisibleDevices)
        {
            var isSelected = SelectedDevice?.Key == device.Key;
            <button class="thm-filter @(isSelected ? "active" : null)"
                    type="button"
                    role="option"
                    aria-selected="@isSelected"
                    title="@($"{device.Name} - {device.TypeLabel} - IP {device.IpAddress}")"
                    @onclick="() => DeviceSelected.InvokeAsync(device)">
                <span>@device.Name</span>
                <small>@device.TypeLabel &middot; IP @device.IpAddress</small>
            </button>
        }
    }
</section>

@code {
    [Parameter, EditorRequired] public UiText Text { get; set; } = default!;
    [Parameter] public IEnumerable<DeviceRefViewModel> Devices { get; set; } = Array.Empty<DeviceRefViewModel>();
    [Parameter] public DeviceRefViewModel? SelectedDevice { get; set; }
    [Parameter] public EventCallback<DeviceRefViewModel> DeviceSelected { get; set; }

    private IReadOnlyList<DeviceRefViewModel> VisibleDevices => Devices.ToList();
}
